{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/process.js", "use": "@vercel/node" },
    { "src": "api/invoices.js", "use": "@vercel/node" },
    { "src": "api/stats.js", "use": "@vercel/node" },
    { "src": "api/update.js", "use": "@vercel/node" },
    { "src": "api/delete.js", "use": "@vercel/node" },
    { "src": "api/invoice/[id].js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/process", "dest": "/api/process" },
    { "src": "/api/invoices", "dest": "/api/invoices" },
    { "src": "/api/stats", "dest": "/api/stats" },
    { "src": "/api/update", "dest": "/api/update" },
    { "src": "/api/delete", "dest": "/api/delete" },
    { "src": "/api/invoice/(.*)", "dest": "/api/invoice/[id]" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

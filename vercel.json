{
  "version": 2,
  "functions": {
    "api/process.js": { "maxDuration": 60, "memory": 1024 },
    "api/invoices.js": { "maxDuration": 10 },
    "api/stats.js": { "maxDuration": 10 },
    "api/update.js": { "maxDuration": 10 },
    "api/delete.js": { "maxDuration": 10 },
    "api/invoice/[id].js": { "maxDuration": 10 }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
